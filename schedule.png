        body {
            background-color: rgb(241, 241, 241);
            margin: 0;
            padding: 0;
        }
       
        header {
            background-color: rgb(1, 12, 77);
            color: white;
            display: flex;
            padding: 0.5em;
            box-shadow: 4px 4px 10px rgb(93, 91, 110);
            width: 100%;
           
        
        }
        nav ul {
            display: flex;
            justify-content: space-between;
            gap: 700px;
            font-family: cursive; 
            
           
        }
        nav li {
            list-style: none;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
        }
        .logo img {
            width:  80px;
            height: 80px;
        }
        li .logo {
            justify-content: flex-start;

        }
        .timetable {
            font-size: 3em;
            font-weight: 900;
            text-align: center;
        }
        .container {
            display: grid;
            grid-template-columns: repeat(6, 1fr) ;  
            grid-template-rows: 0.5fr repeat(9, 1fr);
            margin-bottom: 0;
           
        }
        .box {
            margin-left: 40px;
            margin-right: 40px;
            align-items: center;
            justify-content: center;
            align-items: center;
            background-color: rgb(241, 240, 240);
            border: 1px rgb(190, 188, 188) solid;
            box-shadow: 5px 8px 13px rgb(75, 70, 116);
             overflow-x: auto;
            margin-bottom: 20px;
            border-radius: 13px;

        }
        .print {
            width: 200px;
            height: 50px;
            background-color: rgb(28, 133, 2);
            box-shadow: 2px 8px 13px rgb(212, 202, 202);
            font-family: cursive;
            border-radius: 10px;
            margin-bottom: 10px;
            font-size: 1em;
            margin-left: 20px;
            align-items: center;
            justify-items: flex-end;
            justify-content: center;
            

        }
        .content {
            margin-left: 80px;
            font-size: 1.3em;
            margin-bottom: 100px;
        }
        .tea, 
        .lunch {
           grid-column: span 5;  
           text-align: center;
           display:flex;
            background: rgb(231, 167, 49);
            justify-content:center;
           font-weight: bold;
          align-items:center;
        }
        
        #day {
            background-color: rgb(0, 88, 0);
            text-align: center;
            height: 4em;
            font-size: 1.2em;
            color: white;
        }

        .cell {
            border: 1px solid rgb(207, 207, 207);
            padding: 5px;
            height: 10em;
            justify-content: center;
            font-family: 'Times New Roman', Times, serif;
            font-size: 1em;
        }
        footer {
            height: 100px;
            background-color: rgb(5, 17, 87);
        }
        .footer {
            background-color: rgb(1, 12, 77);
            height: 100px;
            padding-top: 10px;
            
        }
        .footer p {
            justify-content: baseline;
            text-align: center;
            color: white;
           

        }
        button {
            text-decoration: none;
            background-color: red;
            color: white;
            border: none;
            width: 80px;
            margin: 5px;
            cursor: pointer;
            height: 40px;
            border-radius: 11px;
        }
        button:hover {
            background-color: rgb(196, 194, 194);
            color: black;
        }
        #save {
           width: 200px;
            height: 50px;
            background-color: rgb(16, 77, 1);
            box-shadow: 2px 8px 13px rgb(212, 202, 202);
            font-family: cursive;
            border-radius: 10px;
            margin-bottom: 10px;
            font-size: 1em;
            display: flex;
            justify-self: flex-end;
            align-items: center;
            justify-items: flex-end;
            justify-content: center;
        }
        .buttons {
            display: inline-flex;
            justify-content: space-between;
            gap: 50px;
            
        }
        a {
            display: inline-flex;
            gap: 10px;
            padding: 10px;
            justify-content: flex-end;
            text-decoration: none;
            
        }
     
        .time {
            font-family: cursive;
            font-size: 1em;
            text-align: center;
            font-weight: 500;
            background-color: rgb(1, 12, 77);
            color: white;
            border: 1px rgb(206, 205, 205) solid;
        }
        #generate {
            width: 200px;
            height: 50px;
            background-color: rgb(16, 77, 1);
            box-shadow: 2px 8px 13px rgb(212, 202, 202);
            font-family: cursive;
            border-radius: 10px;
            font-size: 1em;
            margin-left: 80px;
            margin-bottom: 10px;
            align-items: flex-start;
            justify-content: center;
            
        }
        #generate:hover {
              background-color: rgb(97, 92, 92);
              color: black;
              
        }
        .body {
            background-color: rgb(235, 235, 235);
            border-radius: 10px;
            justify-content: center;
            align-items: center;
            margin: 10px;
            box-shadow: 2px 8px 13px rgb(212, 202, 202);
        }
         .subject {
           
            padding: 10px;
            justify-content: center;
            text-align: center;
            justify-items: center;
            width: 200px;
            margin: 0 auto 10px auto;
            display: flex;
            height: 40%;
            flex-direction: column;
            margin-bottom: 10px;
            border-radius: 2px;
            box-shadow: 1px 2px 5px rgb(93, 91, 110);
         }
       .popup{
         display:none;
          position:fixed;
           inset:0;
            background:rgba(0,0,0,0.45);
             z-index:9999; 
            }
        .popup-content{
             background:#fff;
              width:320px; 
              height: 300px;
              margin:8% auto;
              background-color: rgb(240, 240, 240);
               padding:16px;
                border-radius:13px;
                 box-shadow:0 8px 24px rgba(0,0,0,0.2);
                }
        .popup-content label{
            display:block;
            margin-top:8px;
        }
       .popup-content select{
        width:100%;
        padding:6px;
        margin-top:4px;
    }


        @media (max-width: 1280px) {
            body {
                font-size: 0.8em;
            }
            button {
                width: 60px;
                height: 30px;
                font-size: 0.8em;
            }
            .time {
                height: 4em;
                 
            }
            .timetable img{
                width: 50px;
                height: 50px;
            }
            .logo img {
                width: 80px;
                height: 80px;
            }
            nav ul {
                gap: 500px;
            }
            .cell {
                height: 8em;
            }
            .subject {
                width: 150px;
            }
            .lunch, .tea {
                width: 100%;
                text-align: center;
                align-content: center;
                display:flex;
                height: 6em;
                font-size: 1.2em;
             
            }
            
        }
        @media (max-width: 1024px) {
            body {
                font-size: 0.8em;
            }
            button {
                width: 60px;
                height: 30px;
                font-size: 0.8em;
            }
           
            .timetable img{
                width: 50px;
                height: 50px;
            }
            .logo img {
                width: 80px;
                height: 80px;
            }
            nav ul {
                gap: 400px;
            }
            .delete-generated-btn {
                margin-left: 350px;
            }
            .cell {
                width: 180px;
            }
            .subject {
                width: 150px;
            }
            .time {
                width: 150px;
                text-align: center;


            }
        }
        @media (max-width: 800px) {
            body {
                font-size: 0.7em;
            }
           
            .timetable img{
                width: 45px;
                height: 45px;
            }
            .logo img {
                width: 50px;
                height: 50px;
            }
            nav ul {
                gap: 300px;
            }
            .delete-generated-btn {
                margin-left: 250px;
            }
        }
        @media (max-width: 600px) {
            body {
                font-size: 0.6em;
            
            
            }
           
            .timetable img{
                width: 40px;
                height: 40px;
            }
            .logo img {
                width: 50px;
                height: 50px;
            }
            nav ul {
                gap: 200px;
            }
            .delete-generated-btn {
                margin-left: 150px;
            }
            
        }
        